{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Issuer": "SecureAPIGateway",
    "Audience": "SecureAPIGateway-Clients",
    "SecretKey": "MySuperSecretKey_ChangeThisInProduction_2024!",
    "ExpiryMinutes": 60
  },
  "RateLimitSettings": {
    "MaxRequestsPerWindow": 100,
    "WindowSeconds": 60
  },
  "AiServiceSettings": {
    "BaseUrl": "http://localhost:5001",
    "AnalyzeEndpoint": "/api/analyze",
    "TimeoutSeconds": 5
  }
}
